# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains live trading credentials.

# Stocksdeveloper.in → Zerodha webhook credentials
STOCKSDEVELOPER_API_KEY=your_api_key_here
STOCKSDEVELOPER_ACCOUNT=your_account_name_here   # e.g. AbhiZerodha

# Optional: override any config parameter without changing code
# ORB_TOP_N_STOCKS=25
# ORB_MAX_POSITIONS=10
# ORB_VOLUME_MULTIPLIER=1.15
# ORB_CHASE_LIMIT_PCT=0.010
# ORB_ENTRY_CUTOFF_TIME=11:00
# ORB_ENTRY_CUTOFF_SECONDARY=11:30
# ORB_POSITION_SCALE=1.0
# POSITION_SIZE_INR=150000
